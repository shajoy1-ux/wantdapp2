# ─────────────────────────────────────────────────────────────────────────────
# wantd.in — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── RAZORPAY (Payment Gateway) ───────────────────────────────────────────────
# Sign up at https://dashboard.razorpay.com
# Use Test Mode keys during development (prefix: rzp_test_...)
# Switch to Live Mode keys before going live (prefix: rzp_live_...)
#
# Server-side key (secret — never expose to browser)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Client-side key (safe to expose — used in browser to init Razorpay checkout)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX

# ── WHATSAPP BUSINESS API ────────────────────────────────────────────────────
# Recommended providers for India: WATI (wati.io) or Interakt (interakt.shop)
#
# WATI setup:
#   1. Sign up at https://wati.io
#   2. Connect your WhatsApp Business number
#   3. Get your API endpoint from Settings > API
#   4. Generate an API key from Settings > API Access Token
#
# Interakt setup:
#   1. Sign up at https://app.interakt.ai
#   2. Connect WhatsApp Business number
#   3. Find API key at Settings > Developer API
#
WHATSAPP_API_KEY=eyJhbGciOiJIUzI1NiJ9.XXXXXXXXXXXX
WHATSAPP_API_URL=https://live-mt-server.wati.io/api/v1/sendSessionMessage/+91XXXXXXXXXX

# ── NEXT.JS ──────────────────────────────────────────────────────────────────
# Set to your production domain before deploying
NEXT_PUBLIC_SITE_URL=https://www.wantd.in

# ── OPTIONAL: Supabase (if you migrate from localStorage to a real DB) ───────
# Sign up at https://supabase.com — free tier is generous
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXX
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXX

# ── OPTIONAL: Email (for transactional emails like bid notifications) ─────────
# Recommended: Resend (resend.com) — free tier: 3,000 emails/month
# RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
# EMAIL_FROM=noreply@wantd.in
